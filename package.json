{
  "name": "nso-kryptonite-platform",
  "version": "1.0.0",
  "description": "NSO Kryptonite Platform — Unified Adversarial Defense Command Center",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch api/boot.ts",
    "dev:client": "vite",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "start": "node dist/server.js",
    "check": "tsc --noEmit && tsc -p tsconfig.server.json --noEmit",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx db/seed.ts",
    "db:secure-wipe": "tsx scripts/secure-wipe.ts",
    "audit:export": "tsx core/audit-chain/export.ts",
    "audit:verify": "tsx core/audit-chain/verify.ts",
    "audit:anchor": "tsx core/audit-chain/anchor.ts",
    "killswitch:activate": "tsx core/killswitch/activate.ts",
    "mesh:remove-node": "tsx core/mesh/remove-node.ts",
    "mesh:dissolve-gateway": "tsx core/mesh/dissolve.ts",
    "evidence:seal": "tsx core/audit-chain/seal-evidence.ts",
    "evidence:verify": "tsx core/audit-chain/verify-evidence.ts",
    "healthcheck": "tsx scripts/healthcheck.ts"
  },
  "dependencies": {
    "hono": "^4.6.0",
    "@trpc/server": "^11.0.0",
    "@trpc/client": "^11.0.0",
    "drizzle-orm": "^0.33.0",
    "mysql2": "^3.11.0",
    "jose": "^5.9.0",
    "zod": "^3.23.0",
    "ws": "^8.18.0",
    "ioredis": "^5.4.0",
    "@tanstack/react-query": "^5.59.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router": "^7.0.0",
    "tailwindcss": "^3.4.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "tailwind-merge": "^2.5.0",
    "lucide-react": "^0.454.0",
    "@radix-ui/react-dialog": "^1.1.0",
    "@radix-ui/react-dropdown-menu": "^2.1.0",
    "@radix-ui/react-tabs": "^1.1.0",
    "@radix-ui/react-tooltip": "^1.1.0",
    "@radix-ui/react-toast": "^1.2.0",
    "recharts": "^2.13.0",
    "three": "^0.170.0",
    "@react-three/fiber": "^8.17.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.0",
    "@types/three": "^0.170.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "tsx": "^4.19.0",
    "drizzle-kit": "^0.30.0",
    "vitest": "^2.1.0",
    "@playwright/test": "^1.48.0",
    "prettier": "^3.3.0",
    "concurrently": "^9.0.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
