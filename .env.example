# NSO Kryptonite Platform — Environment Configuration
# Copy to .env and fill in your values

# Application
NODE_ENV=development
APP_NAME="NSO Kryptonite Platform"
APP_VERSION=1.0.0

# Database
DATABASE_URL=mysql://user:password@localhost:3306/nso_kryptonite

# Redis
REDIS_URL=redis://localhost:6379

# Mesh
MESH_GATEWAY_URL=wss://mesh-gateway:51820
WIREGUARD_ENDPOINT=mesh-gateway
WIREGUARD_PORT=51820
MESH_HEARTBEAT_INTERVAL=60

# Authorization
JWT_SECRET=your-ed25519-private-key-here
TOKEN_TTL_SECONDS=60
BLOCKCHAIN_ANCHOR_INTERVAL=3600

# OBLISK AI
VLLM_URL=http://localhost:8000
LLM_MODEL=meta-llama/Llama-3-70B-Instruct
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.7

# Telemetry
ZEEK_HOST=localhost
ZEEK_PORT=47761
EDR_HOST=localhost
EDR_PORT=443

# Proxmox (for training ranges)
PROXMOX_HOST=proxmox.local
PROXMOX_USER=root@pam
PROXMOX_TOKEN_ID=nso-kryptonite
PROXMOX_TOKEN_SECRET=your-token-secret

# SDR (for wireless modules)
HACKRF_DEVICE=/dev/hackrf
UBERTOOTH_DEVICE=/dev/ubertooth
SDR_FREQUENCY_MIN=2400000000
SDR_FREQUENCY_MAX=2500000000

# Kill Switch
KILLSwitch_BIOMETRIC_REQUIRED=true
KILLSwitch_HOLD_SECONDS=3

# Logging
LOG_LEVEL=info
AUDIT_LOG_PATH=/var/log/nso-kryptonite/audit.log
TELEMETRY_BUFFER_SIZE=10000
